# Microsoft Graph API (Azure AD App Registration)
AZURE_CLIENT_ID=your-app-client-id
AZURE_TENANT_ID=your-tenant-id
# No client secret needed — using auth code + PKCE (public client)

# AWS Bedrock
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-2

# Bedrock Model
LLM_MODEL=us.anthropic.claude-opus-4-6-v1

# Server
PORT=3456

# Your email (for classification — detecting "To: you" vs CC)
USER_EMAIL=your.email@company.com

# Sync interval in minutes (Graph API mode only)
SYNC_INTERVAL_MINUTES=15

# Webhook secret (optional — for external webhook mode only)
WEBHOOK_SECRET=

# OneDrive drop folder (Power Automate → OneDrive → local sync)
# Power Automate writes JSON files to this OneDrive folder; server watches for them.
# Example: ~/Library/CloudStorage/OneDrive-Amazon/Office-Drop
DROP_FOLDER=

# How often to check the drop folder (seconds)
DROP_POLL_SECONDS=10
